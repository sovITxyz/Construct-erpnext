        },
        {
            "fieldname": "sv_nrc",
            "label": "NRC",
            "fieldtype": "Data",
            "insert_after": "sv_nit",
            "module": "Construct Admin",
            "description": "N\u00famero de Registro de Contribuyente"
        }
    ],
    "Customer": [
        {
            "fieldname": "sv_taxpayer_type",
